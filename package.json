{
  "name": "panaderia-exchange",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Internal bread ordering & settlement marketplace (MVP)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev -w @panaderia/api",
    "dev:web": "npm run dev -w @panaderia/web",
    "build": "npm run build -w @panaderia/shared && npm run build -w @panaderia/web && npm run build -w @panaderia/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run db:generate -w @panaderia/api",
    "db:migrate": "npm run db:migrate -w @panaderia/api",
    "db:seed": "npm run db:seed -w @panaderia/api",
    "db:reset": "npm run db:reset -w @panaderia/api",
    "setup": "npm install && npm run build -w @panaderia/shared && npm run db:migrate && npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
