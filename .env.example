# Copy to .env and adjust. NEVER commit .env (it is gitignored).

# --- Database ---
# Local Postgres (Homebrew default uses your OS username, no password).
DATABASE_URL=postgresql://localhost:5432/panaderia_dev

# --- API server ---
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed web origins (the Vite dev server).
WEB_ORIGIN=http://localhost:5173

# --- Sessions ---
# Used to sign/identify the session cookie. Generate a long random string in prod.
SESSION_SECRET=dev-only-insecure-change-me
SESSION_COOKIE_NAME=panaderia_sid
# Session lifetime in days.
SESSION_TTL_DAYS=7

# --- Seed admin (dev convenience ONLY; change before any real use) ---
SEED_ADMIN_EMAIL=admin@admin.com
SEED_ADMIN_PASSWORD=123ABC

# --- Email (stubbed in dev) ---
# EMAIL_PROVIDER: "console" (default, logs to stdout/DB) or "resend".
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@panaderia.local
# Only needed when EMAIL_PROVIDER=resend:
RESEND_API_KEY=

# --- Frontend (Vite) — must be prefixed VITE_ to be exposed to the browser ---
VITE_API_BASE_URL=/api
